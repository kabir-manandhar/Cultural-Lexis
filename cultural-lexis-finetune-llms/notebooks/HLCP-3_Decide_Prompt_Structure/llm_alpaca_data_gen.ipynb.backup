   "source": [
    "# en has no header so we need to add it as relation, cue, association and freq\n",
    "cols = ['relation', 'cue', 'association', 'freq']\n",
    "swow_en_df = pd.read_csv(swow_en_path, names=cols, sep='\\t')\n",
    "swow_zh_df = pd.read_excel(swow_zh_path)\n",
    "swow_us_df = pd.read_csv(swow_us_path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "swow_us_df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [],
   "source": [
    "# a function that groupby cue and sort association by freq\n",
    "\n",
    "def group_sort(df):\n",
    "    df = df.groupby('cue').apply(lambda x: x.sort_values('freq', ascending=False)).reset_index(drop=True)\n",
    "    # get return a dictionary where the key is the cue and the value is the association list \n",
    "    get = df.groupby('cue')['association'].apply(list).to_dict()\n",
    "    return get"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
