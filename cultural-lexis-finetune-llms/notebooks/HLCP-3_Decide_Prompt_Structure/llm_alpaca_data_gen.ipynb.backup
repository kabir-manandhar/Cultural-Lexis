   ],
   "source": [
    "swow_en_dict = group_sort(swow_en_df)\n",
    "swow_zh_dict = group_sort(swow_zh_df)\n",
    "swow_us_dict = group_sort(swow_us_df)\n",
    "\n",
    "print('length of en:', len(swow_en_dict))\n",
    "print('length of zh:', len(swow_zh_dict))"
   ]
