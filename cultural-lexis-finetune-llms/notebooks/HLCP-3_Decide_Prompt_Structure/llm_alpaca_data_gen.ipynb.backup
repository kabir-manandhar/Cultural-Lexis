   "source": [
    "# RMB remove cache first \n",
    "\n",
    "dataset_path = os.path.join(os.environ['WORKING_DIR'], 'data/03_primary/llm_swow_finetune_dataset')\n",
    "\n",
    "sample_data_config = \"swow_en\"\n",
    "\n",
    "sample_split = \"train\"\n",
    "\n",
    "sample_dataset = datasets.load_dataset(\n",
    "    dataset_path, \n",
    "    sample_data_config,\n",
    "    split=sample_split\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "{'instruction': 'Given a cue word, your task is to generate a comprehensive list of words associated with the cue word. Aim to cover as many relevant contexts, uses, and meanings as possible without repeating similar concepts. List a target of 80 to 96 words that together provide a broad and insightful representation of all significant associations. Focus on revealing both common and unique aspects related to the cue word to ensure a balanced and thorough exploration of potential associations. Words should be distinct from each other. Your response shall only be the list of associated words. Do not generate words conditioned on the presence of other words but rather focus on the cue word itself.',\n",
       " 'input': 'imp',\n",
       " 'output': 'small, dwarf, sprite, mischievous, little, naughty, short, scamp, tyrone, goblin, red, game  of  thrones, cheeky, demon, green, funny, child, trickery, fiend, rascal, devilish, magic, puck, car, playful, troll, impish, person, throne, goofy, humor, syrian, sad, comical, whimsical, gargoyle, wings, efreet, if, perversity, mystical, fire, brat, sheepish, impertinent, bird, small  devil, tease, lord  of  misrule, weird, diabolic, video  game, what, blank, not  nice, irrelevant, pinch, impossible, ugly, jackass, midget, small  cute  child, prankster, cleverness, television  show, implies, home  stuck, superman, small  man, daemon, cherubic, fictional, myth, feeble, retarded, mean, unattractive, man, impractical, leprechaun, perverse, doom, fairy  tales, forest, silly, fantasy',\n",
       " 'system': 'You are a sophisticated language model designed to explore word associations comprehensively.'}"
      ]
     },
     "execution_count": 18,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
